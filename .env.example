# ─── Supabase ──────────────────────────────────────────────
VITE_SUPABASE_URL=https://fkxykvzsqdjzhurntgah.supabase.co
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── EasyPost ──────────────────────────────────────────────
# Edge functions pick the key by the shipment's is_test flag:
# test shipments → EASYPOST_TEST_API_KEY (EZTK…), live → EASYPOST_API_KEY (EZAK…).
EASYPOST_TEST_API_KEY=
EASYPOST_API_KEY=
# Optional — when set, the webhook handler verifies the inbound HMAC signature.
EASYPOST_WEBHOOK_HMAC_SECRET=

# ─── Stripe ────────────────────────────────────────────────
# The code reads MODE-SUFFIXED names. Set the _TEST pair for local dev and
# the _LIVE pair in production env — do not rely on un-suffixed fallbacks.
VITE_STRIPE_PUBLISHABLE_KEY_TEST=pk_test_
VITE_STRIPE_PUBLISHABLE_KEY_LIVE=pk_live_
STRIPE_SECRET_KEY_TEST=sk_test_
STRIPE_SECRET_KEY_LIVE=sk_live_
STRIPE_WEBHOOK_SECRET_TEST=whsec_
STRIPE_WEBHOOK_SECRET_LIVE=whsec_

# ─── Resend ────────────────────────────────────────────────
RESEND_API_KEY=

# ─── App ───────────────────────────────────────────────────
VITE_APP_URL=http://localhost:5173
VITE_SHORT_LINK_BASE=sendmo.co/s

# ─── Monitoring (T1-3) ────────────────────────────────────
# Both optional — unset means the SDK never initializes (ships-inert).
# Set in Vercel (Production + Preview for Sentry), not locally.
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
# Optional PostHog host override (defaults to https://us.i.posthog.com)
VITE_POSTHOG_HOST=

# ─── EndShipper (USPS labels) ─────────────────────────────
SENDMO_COMPANY=SendMo
SENDMO_STREET=388 Townsend St
SENDMO_CITY=San Francisco
SENDMO_STATE=CA
SENDMO_ZIP=94107
SENDMO_PHONE=4155550100
SENDMO_EMAIL=shipping@sendmo.co
